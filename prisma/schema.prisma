generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model pengguna {
  id_pengguna     BigInt            @id @default(autoincrement())
  nama            String
  surel           String            @unique
  kata_sandi      String
  bio             String?           @db.Text
  peran           Peran             @default(SISWA)
  aktif           Boolean           @default(true)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  kelas           Int?
  aktivitas       aktivitas[]
  notifikasi      notifikasi[]
  progres_latihan progres_latihan[]
  progres_materi  progres_materi[]

  @@map("pengguna")
}

model latihan {
  id_latihan       BigInt            @id @default(autoincrement())
  judul            String
  deskripsi        String            @db.Text
  ikon             String?
  warna            String?
  total_pertanyaan Int               @default(0)
  aktif            Boolean           @default(true)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  pertanyaan       pertanyaan[]
  progres_pengguna progres_latihan[]

  @@map("latihan")
}

model materi_generated {
  id           String             @id @default(cuid())
  judul        String
  prompt       String             @db.Text
  konten       String             @db.Text
  model        String
  audience     String?
  kelas        Int?               // Kelas untuk siswa (1-6 SD)
  format       String             @default("markdown")
  created_by   BigInt?
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  progres      progres_materi[]

  @@map("materi_generated")
}

model progres_materi {
  id_pengguna BigInt
  id_materi   String
  created_at  DateTime         @default(now())
  id          String           @id @default(cuid())
  selesai_at  DateTime         @default(now())
  materi      materi_generated @relation(fields: [id_materi], references: [id])
  pengguna    pengguna         @relation(fields: [id_pengguna], references: [id_pengguna])

  @@unique([id_pengguna, id_materi])
  @@index([id_materi], map: "progres_materi_id_materi_fkey")
  @@map("progres_materi")
}

model pertanyaan {
  id_pertanyaan   BigInt   @id @default(autoincrement())
  id_latihan      BigInt?
  kelas           Int?     // Kelas untuk siswa (1-6 SD)
  judul           String?  // Judul soal (UAS, UTS, Ulangan Harian, dll)
  teks_pertanyaan String   @db.Text
  pilihan         Json
  jawaban_benar   String
  jalur_gambar    String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  latihan         latihan? @relation(fields: [id_latihan], references: [id_latihan])

  @@map("pertanyaan")
}

model progres_latihan {
  id_progres  BigInt    @id @default(autoincrement())
  id_pengguna BigInt
  id_latihan  BigInt
  skor        Int       @default(0)
  selesai     DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  latihan     latihan   @relation(fields: [id_latihan], references: [id_latihan])
  pengguna    pengguna  @relation(fields: [id_pengguna], references: [id_pengguna])

  @@index([id_latihan], map: "progres_latihan_id_latihan_fkey")
  @@index([id_pengguna], map: "progres_latihan_id_pengguna_fkey")
  @@map("progres_latihan")
}

model notifikasi {
  id_notifikasi BigInt   @id @default(autoincrement())
  id_pengguna   BigInt
  tipe          String
  judul         String
  pesan         String   @db.Text
  dibaca        Boolean  @default(false)
  created_at    DateTime @default(now())
  pengguna      pengguna @relation(fields: [id_pengguna], references: [id_pengguna])

  @@index([id_pengguna], map: "notifikasi_id_pengguna_fkey")
  @@map("notifikasi")
}

model aktivitas {
  id_aktivitas BigInt    @id @default(autoincrement())
  id_pengguna  BigInt?
  judul        String
  deskripsi    String    @db.Text
  tipe         String
  created_at   DateTime  @default(now())
  pengguna     pengguna? @relation(fields: [id_pengguna], references: [id_pengguna])

  @@index([id_pengguna], map: "aktivitas_id_pengguna_fkey")
  @@map("aktivitas")
}

enum Peran {
  ADMIN
  SISWA
}
