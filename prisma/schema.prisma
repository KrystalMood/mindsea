generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Peran {
  ADMIN
  SISWA
}

enum Kesulitan {
  MUDAH  @map("Mudah")
  SEDANG @map("Sedang")
  SULIT  @map("Sulit")
}

enum JenisKonten {
  PENGENALAN   @map("Pengenalan")
  MATERI_UTAMA @map("Materi Utama")
  LATIHAN      @map("Latihan")
}

model pengguna {
  id_pengguna BigInt   @id @default(autoincrement())
  nama        String
  surel       String   @unique
  kata_sandi  String
  bio         String?  @db.Text
  peran       Peran    @default(SISWA)
  kelas       Int?     // Kelas untuk siswa (1-6 SD)
  aktif       Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  progres_latihan progres_latihan[]
  notifikasi      notifikasi[]
  aktivitas       aktivitas[]

  @@map("pengguna")
}

model latihan {
  id_latihan       BigInt   @id @default(autoincrement())
  judul            String
  deskripsi        String   @db.Text
  ikon             String?
  warna            String?
  total_pertanyaan Int      @default(0)
  aktif            Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relasi
  pertanyaan       pertanyaan[]
  progres_pengguna progres_latihan[]

  @@map("latihan")
}

model materi_generated {
  id           String   @id @default(cuid())
  judul        String
  prompt       String   @db.Text
  konten       String   @db.Text
  model        String
  audience     String?
  format       String   @default("markdown")
  created_by   BigInt?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("materi_generated")
}

model pertanyaan {
  id_pertanyaan   BigInt   @id @default(autoincrement())
  id_latihan      BigInt
  teks_pertanyaan String   @db.Text
  pilihan         Json
  jawaban_benar   String
  jalur_gambar    String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  latihan latihan @relation(fields: [id_latihan], references: [id_latihan])

  @@map("pertanyaan")
}

model progres_latihan {
  id_progres  BigInt    @id @default(autoincrement())
  id_pengguna BigInt
  id_latihan  BigInt
  skor        Int       @default(0)
  selesai     DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  pengguna pengguna @relation(fields: [id_pengguna], references: [id_pengguna])
  latihan  latihan  @relation(fields: [id_latihan], references: [id_latihan])

  @@map("progres_latihan")
}

model notifikasi {
  id_notifikasi BigInt   @id @default(autoincrement())
  id_pengguna   BigInt
  tipe          String
  judul         String
  pesan         String   @db.Text
  dibaca        Boolean  @default(false)
  created_at    DateTime @default(now())

  pengguna pengguna @relation(fields: [id_pengguna], references: [id_pengguna])

  @@map("notifikasi")
}

model aktivitas {
  id_aktivitas BigInt   @id @default(autoincrement())
  id_pengguna  BigInt?
  judul        String
  deskripsi    String   @db.Text
  tipe         String
  created_at   DateTime @default(now())

  pengguna pengguna? @relation(fields: [id_pengguna], references: [id_pengguna])

  @@map("aktivitas")
}