{
  "name": "mindsea",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && next build",
    "db:push": "dotenv -e .env.local -- bunx prisma db push",
    "db:reset": "dotenv -e .env.local -- bunx prisma migrate reset --force",
    "dev": "dotenv -e .env.local -- next dev",
    "format": "prettier --write . --ext .js,.jsx,.ts,.tsx,.json,.md",
    "lint": "eslint",
    "start": "next start",
    "seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@prisma/adapter-mariadb": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-slot": "^1.2.4",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.1.3",
    "next": "16.1.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/axios": "^0.14.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.2.0",
    "react-icons": "^5.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@prisma/engines",
    "prisma",
    "sharp",
    "unrs-resolver"
  ]
}
